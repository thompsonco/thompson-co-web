<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - THOMPSON & CO</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Segoe+UI:wght@400;600&display=swap" rel="stylesheet">
    
    <style>
        /* Fargepalett */
        :root {
            --plum-dark: #3d1328;
            --plum-light: #6b2247;
            --text-dark: #333333;
            --text-light: #ffffff;
            --bg-light: #fdfafb;
            --border-color: #e0e0e0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, sans-serif; scroll-behavior: smooth; }
        body { background-color: var(--bg-light); color: var(--text-dark); line-height: 1.6; overflow-x: hidden; }
        h1, h2, h3, .serif { font-family: 'Playfair Display', serif; }

        /* --- Header --- */
        header { background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.3), transparent); color: var(--text-light); padding: 1.5rem 5%; display: flex; justify-content: space-between; align-items: flex-start; position: absolute; top: 0; left: 0; width: 100%; z-index: 100; }
        .logo-area { display: flex; flex-direction: column; }
        .logo { font-size: 1.8rem; font-weight: 700; letter-spacing: 2px; text-decoration: none; color: white; line-height: 1; }
        
        .breadcrumbs { margin-top: 24px; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.7); display: flex; gap: 5px; align-items: center; }
        .breadcrumbs a { color: rgba(255,255,255,0.85); text-decoration: none; transition: color 0.3s; }
        .breadcrumbs a:hover { color: white; text-decoration: underline; }
        .breadcrumbs span { color: white; font-weight: 600; }

        nav ul { list-style: none; display: flex; gap: 2rem; margin-top: 5px; }
        nav a { color: var(--text-light); text-decoration: none; font-weight: 500; transition: color 0.3s ease; }
        nav a:hover { color: #d1a3b8; }

        /* --- Bildegalleri --- */
        .gallery-section { width: 100%; margin: 0; padding: 0; position: relative; background: #000; }
        .slider-container { position: relative; width: 100%; overflow: hidden; }
        .slides { display: flex; transition: transform 0.5s ease-in-out; width: 100%; }
        .slide { min-width: 100%; height: 85vh; object-fit: cover; cursor: pointer; }
        
        .slider-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.15); color: white; border: none; padding: 1.5rem 1rem; cursor: pointer; font-size: 1.5rem; transition: background 0.3s; z-index: 10; border-radius: 4px; backdrop-filter: blur(5px); }
        .slider-btn:hover { background: rgba(255, 255, 255, 0.3); }
        .prev { left: 20px; } .next { right: 20px; }

        .thumbnails { position: absolute; bottom: 25px; left: 50%; transform: translateX(-50%); z-index: 20; display: flex; gap: 8px; justify-content: center; overflow-x: auto; max-width: 90%; padding: 10px; background: rgba(0,0,0,0.3); border-radius: 8px; backdrop-filter: blur(10px); }
        .thumb { width: 90px; height: 55px; object-fit: cover; border-radius: 4px; cursor: pointer; opacity: 0.5; transition: all 0.3s ease; border: 2px solid transparent; }
        .thumb:hover { opacity: 0.9; }
        .thumb.active { opacity: 1; border: 2px solid white; transform: scale(1.05); }

        /* Lightbox */
        .lightbox { display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background-color: #000000; align-items: center; justify-content: center; }
        .lightbox-content { max-width: 90%; max-height: 85vh; object-fit: contain; animation: zoom 0.3s ease-in-out; }
        @keyframes zoom { from {transform: scale(0.9); opacity: 0;} to {transform: scale(1); opacity: 1;} }
        .close-btn { position: absolute; top: 20px; right: 40px; color: #ffffff; font-size: 40px; cursor: pointer; z-index: 10000; }
        .lightbox-btn { position: absolute; top: 50%; background: rgba(255, 255, 255, 0.1); color: white; border: none; padding: 1.5rem 1rem; cursor: pointer; font-size: 2rem; border-radius: 4px; }
        .lb-prev { left: 20px; } .lb-next { right: 20px; }

        /* Layout Grid */
        .content-grid { max-width: 1200px; margin: 0 auto; padding: 4rem 5% 5rem; display: grid; grid-template-columns: 2fr 1fr; gap: 4rem; }

        /* Sidetittel */
        .page-header { text-align: left; margin-bottom: 2.5rem; }
        .page-header h1 { font-size: 3.5rem; color: var(--plum-dark); margin-bottom: 0.5rem; line-height: 1.1; display: flex; align-items: center; gap: 12px; }
        .icon-action { width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; background: #f0f0f0; border-radius: 50%; color: #999; cursor: pointer; transition: 0.2s; }
        .icon-action:hover { color: var(--plum-dark); background: #e5e5e5; }
        .icon-action svg { width: 12px; height: 12px; } 
        .page-header p { font-size: 1.2rem; color: #666; font-weight: 400; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 1rem; }

        /* Piller */
        .pill-row { display: flex; flex-wrap: nowrap; gap: 6px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: none; }
        .pill-row::-webkit-scrollbar { display: none; }
        .pill { padding: 3px 10px; border-radius: 20px; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.5px; color: #444; border: 1px solid rgba(0,0,0,0.05); white-space: nowrap; cursor: pointer; transition: filter 0.2s; }
        .pill.p-warm { background: #fdf8f0; color: #8a6a3a; }
        .pill.p-blue { background: #f0f4fd; color: #3a5c8a; }
        .pill.p-green { background: #f0fdf4; color: #3a8a5c; }
        .pill.p-pink { background: #fdf0f4; color: #8a3a52; }
        .pill:hover { filter: brightness(0.9); }

        /* Seksjonsoverskrifter */
        .section-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: var(--plum-dark); margin-bottom: 1.5rem; line-height: 1.2; }

        /* Faner */
        .tabs-container { background: white; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); overflow: hidden; height: max-content; margin-bottom: 3rem; border: 1px solid var(--border-color); }
        .tab-buttons { display: flex; background-color: var(--bg-light); border-bottom: 1px solid var(--border-color); overflow-x: auto; }
        .tab-btn { flex: 1; padding: 1.2rem 1rem; border: none; background: none; font-size: 0.95rem; font-weight: 600; color: #666; cursor: pointer; transition: all 0.3s ease; border-bottom: 3px solid transparent; white-space: nowrap; }
        .tab-btn.active, .tab-btn:hover { color: var(--plum-dark); border-bottom: 3px solid var(--plum-dark); background-color: white; }
        
        .tab-content { display: none; padding: 2.5rem; animation: fadeIn 0.4s; }
        .tab-content.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .tab-content h2 { color: var(--plum-dark); margin-bottom: 1.5rem; font-size: 1.8rem; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .info-item strong { display: block; color: var(--plum-dark); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.3rem; }

        /* Høyre kolonne: Sidebar er fast */
        .sidebar { background-color: white; padding: 2.5rem 2rem; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); border-top: 5px solid var(--plum-light); height: max-content; position: sticky; top: 120px;}
        
        /* Agent Info */
        .agent-info { display: flex; flex-direction: column; align-items: center; padding-bottom: 2rem; border-bottom: 1px solid var(--border-color); margin-bottom: 2rem; }
        .agent-info img { width: 110px; height: 110px; border-radius: 50%; object-fit: cover; margin-bottom: 1rem; border: 3px solid var(--bg-light); box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .agent-name { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--plum-dark); margin-bottom: 2px; }
        .agent-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: var(--plum-light); margin-bottom: 12px; }
        .agent-contact { font-size: 0.95rem; color: #444; line-height: 1.6; display: flex; align-items: center; gap: 5px; }
        
        .email-copy { cursor: pointer; color: #999; display: inline-flex; transition: 0.2s; }
        .email-copy:hover { color: var(--plum-dark); }
        .email-copy svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; }

        /* Sidebar Knapper */
        .action-btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 1rem; border-radius: 4px; font-weight: 600; margin-bottom: 1rem; transition: all 0.3s ease; text-align: center; cursor: pointer; font-size: 0.95rem; text-decoration: none;}
        .action-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
        
        .action-btn.secondary { background-color: transparent; color: var(--plum-dark); border: 1px solid var(--border-color); }
        .action-btn.secondary:hover { background-color: var(--bg-light); border-color: var(--plum-dark); }
        .action-btn.primary-action { background-color: var(--plum-dark); color: white; border: 1px solid var(--plum-dark); box-shadow: 0 4px 10px rgba(61,19,40,0.15); }
        .action-btn.primary-action:hover { background-color: var(--plum-light); border-color: var(--plum-light); }

        /* Modaler, Skjema og Chat beholdes likt som din original */
        .modal-overlay { display: none; position: fixed; z-index: 10001; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); align-items: center; justify-content: center; backdrop-filter: blur(5px); }
        .modal-box { background-color: white; padding: 2.5rem; border-radius: 8px; width: 90%; max-width: 450px; position: relative; box-shadow: 0 20px 50px rgba(0,0,0,0.2); animation: zoom 0.3s; }
        .close-modal { position: absolute; top: 15px; right: 20px; font-size: 1.5rem; cursor: pointer; color: #666; transition: 0.3s; }
        
        .custom-calendar { border: 1px solid var(--border-color); border-radius: 6px; overflow: hidden; margin-bottom: 1rem; }
        .cal-header { background: var(--plum-dark); color: white; text-align: center; padding: 12px; font-weight: bold; font-family: 'Playfair Display', serif; font-size: 1.2rem; }
        .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; background: var(--border-color); text-align: center; font-size: 0.9rem;}
        .cal-grid span { background: white; padding: 10px 0; cursor: pointer; transition: 0.2s; }
        .cal-grid span.day-name { background: var(--bg-light); font-weight: bold; color: #888; cursor: default; font-size: 0.8rem; text-transform: uppercase;}
        .cal-grid span.day:hover { background: #f5edf1; color: var(--plum-dark); }
        .cal-grid span.day.selected { background: var(--plum-light); color: white; font-weight: bold; }
        .cal-grid span.disabled { background: #f4f4f4; color: #ccc; cursor: not-allowed; }

        .simple-form { display: flex; flex-direction: column; gap: 1rem; }
        .simple-form input, .simple-form select { padding: 0.8rem; border: 1px solid #ccc; border-radius: 4px; font-family: inherit; font-size: 1rem; outline: none; }
        .simple-form input:focus, .simple-form select:focus { border-color: var(--plum-light); }
        .time-row { display: flex; gap: 1rem; }
        .checkbox-group { display: flex; align-items: flex-start; gap: 10px; font-size: 0.85rem; margin-top: 0.5rem; }
        .checkbox-group input { margin-top: 3px; cursor: pointer; }

        .chat-backdrop { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.1); backdrop-filter: blur(3px); z-index: 9997; }
        .chat-window { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.95); width: 90%; max-width: 650px; height: 70vh; max-height: 800px; background: white; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); z-index: 9998; flex-direction: column; overflow: hidden; border: 1px solid var(--border-color); transition: transform 0.3s ease-out; }
        .chat-window.open { transform: translate(-50%, -50%) scale(1); }
        .chat-header { background: var(--plum-dark); color: white; padding: 1.2rem 1.5rem; font-weight: bold; display: flex; justify-content: space-between; align-items: center; font-size: 1.2rem; }
        .minimize-chat { cursor: pointer; font-size: 2rem; line-height: 0.5; transition: color 0.2s; }
        .chat-body { flex: 1; padding: 1.5rem; overflow-y: auto; background: var(--bg-light); display: flex; flex-direction: column; gap: 12px; }
        .chat-msg { padding: 1rem 1.2rem; border-radius: 15px; max-width: 85%; font-size: 1rem; line-height: 1.5; }
        .msg-ai { background: #e9e0e4; color: var(--plum-dark); align-self: flex-start; border-bottom-left-radius: 4px; }
        .msg-user { background: var(--plum-light); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }
        .chat-input-area { display: flex; padding: 1.2rem; border-top: 1px solid var(--border-color); background: white; gap: 10px;}
        .chat-input-area input { flex: 1; border: 1px solid #ccc; padding: 0.8rem 1.2rem; border-radius: 30px; outline: none; font-size: 1rem;}
        .chat-input-area button { background: var(--plum-dark); color: white; border: none; padding: 0.8rem 1.5rem; border-radius: 30px; cursor: pointer; font-weight: bold; font-size: 1rem;}

        .toast { visibility: hidden; min-width: 200px; background-color: var(--plum-dark); color: #fff; text-align: center; border-radius: 4px; padding: 12px; position: fixed; z-index: 10002; left: 50%; bottom: 30px; transform: translateX(-50%); font-size: 0.9rem; box-shadow: 0 4px 15px rgba(0,0,0,0.2); opacity: 0; transition: opacity 0.3s, bottom 0.3s; }
        .toast.show { visibility: visible; opacity: 1; bottom: 50px; }

        footer { background-color: var(--plum-dark); color: var(--text-light); text-align: center; padding: 2rem 5%; border-top: 1px solid #5a1c3b; }
        @media (max-width: 900px) { .content-grid { grid-template-columns: 1fr; gap: 2rem; padding-top: 2rem; } .slide { height: 60vh; } .page-header h1 { font-size: 2.5rem; flex-wrap: wrap; } .chat-window { width: 95%; height: 80vh; } }
    </style>
</head>
<body>

    <div id="copyToast" class="toast">Kopiert!</div>

    <header>
        <div class="logo-area">
            <a href="/" class="logo">THOMPSON & CO.</a>
            <div class="breadcrumbs">
                <a href="/">Hjem</a> > <a href="/lokaler">Lokaler til leie</a> > <span>{{ title }}</span>
            </div>
        </div>
        <nav><ul><li><a href="/lokaler">Søk Eiendommer</a></li></ul></nav>
    </header>

    <main>
        <section class="gallery-section">
            <div class="slider-container">
                <button class="slider-btn prev" onclick="moveSlide(-1)">❮</button>
                <div class="slides" id="imageSlider">
                    {% for bilde in galleri %}
                    <img class="slide" src="{{ bilde }}" alt="{{ title }}" onclick="openLightbox({{ loop.index0 }})">
                    {% endfor %}
                </div>
                <button class="slider-btn next" onclick="moveSlide(1)">❯</button>
            </div>
            
            <div class="thumbnails" id="thumbnailContainer">
                {% for bilde in galleri %}
                <img class="thumb {% if loop.first %}active{% endif %}" src="{{ bilde }}" onclick="goToSlide({{ loop.index0 }})">
                {% endfor %}
            </div>
        </section>

        <section class="content-grid">
            
            <div class="main-content-area">
                
                <div class="page-header">
                    <h1>
                        {{ title }}
                        <span class="icon-action" title="Kopier adresse" onclick="copyText('{{ title }}')">
                            <svg viewBox="0 0 24 24" stroke="currentColor" fill="none"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>
                        </span>
                    </h1>
                    <p>{{ subtitle }}</p>
                    
                    <div class="pill-row">
                        {% for pille in piller %}
                        <span class="pill {{ pille.farge }}" onclick="openMainTab(event, 'nokkel')">{{ pille.tekst }}</span>
                        {% endfor %}
                    </div>
                </div>
                
                <h2 class="section-title">Nøkkelinfo</h2>
                
                <div class="tabs-container">
                    <div class="tab-buttons">
                        <button class="tab-btn main-tab active" onclick="openMainTab(event, 'nokkel')">Om lokalene</button>
                        <button class="tab-btn main-tab" onclick="openMainTab(event, 'okonomi')">Økonomi</button>
                        <button class="tab-btn main-tab" onclick="openMainTab(event, 'fasiliteter')">Fasiliteter</button>
                        <button class="tab-btn main-tab" onclick="openMainTab(event, 'beliggenhet')">Beliggenhet</button>
                        <button class="tab-btn main-tab" onclick="openMainTab(event, 'kapasitet')">Kapasitetsoversikt</button>
                    </div>

                    <div id="nokkel" class="tab-content main-content active">
                        <h2>Om Eiendommen</h2>
                        <p style="margin-bottom: 2rem; color: #555;">{{ nokkelinfo.om_eiendommen }}</p>
                        <div class="info-grid">
                            <div class="info-item"><strong>Ledig Areal</strong><span>{{ nokkelinfo.ledig_areal }}</span></div>
                            <div class="info-item"><strong>Etasje</strong><span>{{ nokkelinfo.etasje_info }}</span></div>
                            <div class="info-item"><strong>Overtakelse</strong><span>{{ nokkelinfo.overtakelse }}</span></div>
                            <div class="info-item"><strong>Standard</strong><span>{{ nokkelinfo.standard }}</span></div>
                        </div>
                    </div>
                    
                    <div id="okonomi" class="tab-content main-content">
                        <h2>Økonomisk Informasjon</h2>
                        <div class="info-grid">
                            <div class="info-item"><strong>Estimert Leie</strong><span>{{ okonomi.estimert_leie }}</span></div>
                            <div class="info-item"><strong>Felleskostnader</strong><span>{{ okonomi.felleskostnader }}</span></div>
                            <div class="info-item"><strong>Leiepris</strong><span>{{ okonomi.leiepris }}</span></div>
                        </div>
                    </div>

                    <div id="fasiliteter" class="tab-content main-content">
                        <h2>Fasiliteter</h2>
                        <ul style="list-style-position: inside; color: #555;">
                            {% for pkt in fasiliteter %}
                            <li>{{ pkt }}</li>
                            {% endfor %}
                        </ul>
                    </div>

                    <div id="beliggenhet" class="tab-content main-content">
                        <h2>Beliggenhet</h2>
                        <div class="info-grid">
                            <div class="info-item"><strong>Område</strong><span>{{ beliggenhet.omrade }}</span></div>
                            <div class="info-item"><strong>Tog / Flytog</strong><span>{{ beliggenhet.tog_fly }}</span></div>
                        </div>
                    </div>

                    <div id="kapasitet" class="tab-content main-content">
                        <h2>Kapasitetsoversikt</h2>
                        <div style="color: #555;">
                            {{ kapasitet | safe }}
                        </div>
                    </div>

                </div>
            </div>

            <aside class="sidebar">
                
                <div class="agent-info">
                    <img src="{% if megler.bilde %}{{ megler.bilde }}{% else %}https://ui-avatars.com/api/?name={{ megler.navn | urlencode }}&background=3d1328&color=fff{% endif %}" alt="{{ megler.navn }}">
                    <h3 class="agent-name">{{ megler.navn }}</h3>
                    <p class="agent-title">{{ megler.tittel }}</p>
                    <div class="agent-contact">
                        {{ megler.telefon }}
                    </div>
                    <div class="agent-contact" style="margin-top: 4px;">
                        {{ megler.epost }} 
                        <span class="email-copy" onclick="copyText('{{ megler.epost }}')" title="Kopier e-post">
                            <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>
                        </span>
                    </div>
                </div>
                
                {% if filer.prospekt_pdf %}
                <a href="{{ filer.prospekt_pdf }}" target="_blank" class="action-btn primary-action">
                    <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    Last ned Prospekt (PDF)
                </a>
                {% endif %}

                {% if filer.plantegning_pdf %}
                <a href="{{ filer.plantegning_pdf }}" target="_blank" class="action-btn secondary">
                    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                    Se Plantegninger (PDF)
                </a>
                {% endif %}

                <button class="action-btn secondary" onclick="openModal('bookingModal')">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    Bestill Privat Visning
                </button>
                <button class="action-btn secondary" style="background-color: var(--bg-light);" onclick="toggleChat()">
                    <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                    Spør AI Assistent
                </button>
            </aside>
        </section>
    </main>

    <div id="lightbox" class="lightbox" onclick="closeLightboxOnBg(event)">
        <span class="close-btn" onclick="closeLightbox()">×</span>
        <button class="lightbox-btn lb-prev" onclick="moveLightboxSlide(-1)">❮</button>
        <img id="lightbox-img" class="lightbox-content" src="">
        <button class="lightbox-btn lb-next" onclick="moveLightboxSlide(1)">❯</button>
    </div>

    <div id="bookingModal" class="modal-overlay" onclick="closeModalOnBgClick(event, 'bookingModal')">
        <div class="modal-box">
            <span class="close-modal" onclick="closeModal('bookingModal')">×</span>
            <h2 style="color: var(--plum-dark); margin-bottom: 1.5rem; font-family: 'Playfair Display', serif; text-align: center;">Velg Dato</h2>
            
            <div class="custom-calendar">
                <div class="cal-header">Mai 2026</div>
                <div class="cal-grid">
                    <span class="day-name">Ma</span><span class="day-name">Ti</span><span class="day-name">On</span><span class="day-name">To</span><span class="day-name">Fr</span><span class="day-name">Lø</span><span class="day-name">Sø</span>
                    <span class="disabled"></span><span class="disabled"></span><span class="disabled"></span><span class="disabled"></span>
                    <span class="day" onclick="selectDay(this)">1</span>
                    <span class="disabled">2</span><span class="disabled">3</span>
                    <span class="day" onclick="selectDay(this)">4</span><span class="day" onclick="selectDay(this)">5</span><span class="day" onclick="selectDay(this)">6</span><span class="day" onclick="selectDay(this)">7</span><span class="day" onclick="selectDay(this)">8</span>
                    <span class="disabled">9</span><span class="disabled">10</span>
                    <span class="day" onclick="selectDay(this)">11</span><span class="day" onclick="selectDay(this)">12</span><span class="day" onclick="selectDay(this)">13</span><span class="day" onclick="selectDay(this)">14</span><span class="day" onclick="selectDay(this)">15</span>
                    <span class="disabled">16</span><span class="disabled">17</span>
                </div>
            </div>
            
            <form class="simple-form" id="visningForm" name="visning" method="POST" data-netlify="true">
                <input type="hidden" name="form-name" value="visning" />
                <input type="hidden" name="eiendom" value="{{ title }}">
                
                <input type="hidden" name="dato" id="valgtDato" value=""> 
                
                <input type="text" name="navn" placeholder="Ditt fulle navn" required>
                <div class="time-row">
                    <input type="text" name="kontakt" placeholder="Telefon eller E-post" required style="flex: 2;">
                    <select name="tid" required style="flex: 1; cursor: pointer;">
                        <option value="" disabled selected>Klokkeslett</option>
                        <option value="08:00">08:00</option><option value="09:00">09:00</option>
                        <option value="10:00">10:00</option><option value="11:00">11:00</option>
                        <option value="12:00">12:00</option><option value="13:00">13:00</option>
                        <option value="14:00">14:00</option><option value="15:00">15:00</option>
                        <option value="16:00">16:00</option>
                    </select>
                </div>
                <div class="checkbox-group">
                    <input type="checkbox" id="terms" required>
                    <label for="terms">Jeg godtar Thompson & Co sine vilkår</label>
                </div>
                <button type="submit" id="submitBtn" class="action-btn primary-action" style="margin-top: 0.5rem; opacity: 0.5; cursor: not-allowed;" disabled>Send forespørsel om visning</button>
            </form>
        </div>
    </div>

    <div class="chat-backdrop" id="chatBackdrop" onclick="toggleChat()"></div>
    <div id="aiChat" class="chat-window">
        <div class="chat-header">
            <span style="font-family: 'Playfair Display', serif;">AI Thompson Assistent</span>
            <span class="minimize-chat" title="Legg ned" onclick="toggleChat()">−</span>
        </div>
        <div class="chat-body" id="chatBody">
            <div class="chat-msg msg-ai">Velkommen. Jeg assisterer {{ megler.navn }}. Er det en spesifikk detalj om {{ title }} du ønsker å vite mer om?</div>
        </div>
        <div class="chat-input-area">
            <input type="text" id="chatInput" placeholder="Spør meg om bygget..." onkeypress="handleChatKeyPress(event)">
            <button onclick="sendChatMessage()">Spør</button>
        </div>
    </div>

    <script>
        // Kopiering (Toast varsel)
        function copyText(text) {
            navigator.clipboard.writeText(text).then(() => {
                const toast = document.getElementById("copyToast");
                toast.className = "toast show";
                setTimeout(function(){ toast.className = toast.className.replace("show", ""); }, 3000);
            });
        }

        // Bildegalleri
        let currentSlideIndex = 0;
        const slider = document.getElementById('imageSlider');
        const slides = document.querySelectorAll('.slide');
        const thumbs = document.querySelectorAll('.thumb');
        
        function updateSlider() {
            if(!slider || slides.length === 0) return;
            slider.style.transform = `translateX(${-(currentSlideIndex * 100)}%)`;
            thumbs.forEach(t => t.classList.remove('active'));
            if(thumbs[currentSlideIndex]) thumbs[currentSlideIndex].classList.add('active');
        }
        function moveSlide(dir) {
            if(slides.length === 0) return;
            currentSlideIndex = (currentSlideIndex + dir + slides.length) % slides.length;
            updateSlider();
        }
        function goToSlide(idx) { currentSlideIndex = idx; updateSlider(); }

        // Lightbox
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        let isLightboxOpen = false;
        
        function openLightbox(idx) {
            isLightboxOpen = true; 
            currentSlideIndex = idx; updateSlider();
            lightboxImg.src = slides[currentSlideIndex].src;
            lightbox.style.display = 'flex';
        }

        function closeLightbox() { isLightboxOpen = false; lightbox.style.display = 'none'; }
        function closeLightboxOnBg(e) { if(e.target === lightbox) closeLightbox(); }
        function moveLightboxSlide(dir) { moveSlide(dir); lightboxImg.src = slides[currentSlideIndex].src; }

        document.addEventListener('keydown', function(event) {
            if (isLightboxOpen) {
                if (event.key === 'Escape') closeLightbox();
                else if (event.key === 'ArrowRight') moveLightboxSlide(1);
                else if (event.key === 'ArrowLeft') moveLightboxSlide(-1);
            }
        });

        // Hoved-faner
        function openMainTab(evt, tabId) {
            document.querySelectorAll('.main-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.main-tab').forEach(b => b.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            
            if(evt.currentTarget.classList.contains('pill')) {
                const buttons = document.querySelectorAll('.main-tab');
                for(let i=0; i<buttons.length; i++) {
                    if(buttons[i].getAttribute('onclick').includes(tabId)) buttons[i].classList.add('active');
                }
                document.querySelector('.tabs-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
            } else {
                evt.currentTarget.classList.add('active');
            }
        }

        // Modaler
        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }
        function closeModalOnBgClick(e, id) { if(e.target.id === id) closeModal(id); }

        // --- SKJEMA, KALENDER OG VALIDERING ---
        
        // 1. Sjekker om alt er fylt ut
        function checkFormValidity() {
            const form = document.getElementById('visningForm');
            const btn = document.getElementById('submitBtn');
            if(!form || !btn) return;

            const navn = form.querySelector('[name="navn"]').value.trim();
            const kontakt = form.querySelector('[name="kontakt"]').value.trim();
            const tid = form.querySelector('[name="tid"]').value;
            const dato = document.getElementById('valgtDato').value;
            const terms = document.getElementById('terms').checked;

            // Lås opp hvis alt har en verdi, ellers lås igjen
            if (navn !== '' && kontakt !== '' && tid !== '' && dato !== '' && terms) {
                btn.disabled = false;
                btn.style.opacity = "1";
                btn.style.cursor = "pointer";
            } else {
                btn.disabled = true;
                btn.style.opacity = "0.5";
                btn.style.cursor = "not-allowed";
            }
        }

        // 2. Kalenderklikk
        function selectDay(element) {
            if(element.classList.contains('disabled')) return;
            
            // Fjerner farge fra gamle valg og setter på ny
            document.querySelectorAll('.cal-grid .day').forEach(d => d.classList.remove('selected'));
            element.classList.add('selected');
            
            // Lagrer datoen i det usynlige feltet
            document.getElementById('valgtDato').value = element.innerText + ". Mai 2026";
            
            // Sjekk om skjemaet er klart til å sendes
            checkFormValidity();
        }

        // 3. Koble validering til skrivefelter og knapper
        const formEl = document.getElementById('visningForm');
        if(formEl) {
            // Vi legger funksjonen på window-objektet slik at kalenderen kan nå den
            window.checkFormValidity = checkFormValidity;
            
            formEl.addEventListener('input', checkFormValidity);
            formEl.addEventListener('change', checkFormValidity);
            
            // Send i bakgrunnen uten reload (hindrer 404)
            formEl.addEventListener('submit', function(e) {
                e.preventDefault();
                const formData = new FormData(formEl);
                fetch('/', {
                    method: 'POST',
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: new URLSearchParams(formData).toString()
                })
                .then(() => {
                    closeModal('bookingModal');
                    const toast = document.getElementById("copyToast");
                    toast.innerText = "Takk! Forespørsel er sendt.";
                    toast.className = "toast show";
                    setTimeout(function(){ 
                        toast.className = toast.className.replace("show", ""); 
                        toast.innerText = "Kopiert!"; 
                    }, 4000);
                    
                    // Nullstill alt etter vellykket sending
                    formEl.reset();
                    document.getElementById('valgtDato').value = "";
                    document.querySelectorAll('.cal-grid .day').forEach(d => d.classList.remove('selected'));
                    checkFormValidity();
                })
                .catch((error) => alert('Beklager, det oppstod en feil: ' + error));
            });
        }

        // --- AI CHAT ---
        function toggleChat() {
            const chat = document.getElementById('aiChat');
            const backdrop = document.getElementById('chatBackdrop');
            if (chat.style.display === 'flex') {
                chat.classList.remove('open');
                setTimeout(() => { chat.style.display = 'none'; backdrop.style.display = 'none'; }, 150); 
            } else {
                chat.style.display = 'flex'; backdrop.style.display = 'block';
                setTimeout(() => chat.classList.add('open'), 10);
                document.getElementById('chatInput').focus();
            }
        }
        function handleChatKeyPress(e) { if(e.key === 'Enter') sendChatMessage(); }
        function sendChatMessage() {
            const input = document.getElementById('chatInput');
            if(!input.value.trim()) return;
            const chatBody = document.getElementById('chatBody');
            chatBody.innerHTML += `<div class="chat-msg msg-user">${input.value}</div>`;
            input.value = '';
            chatBody.scrollTop = chatBody.scrollHeight;
            setTimeout(() => {
                chatBody.innerHTML += `<div class="chat-msg msg-ai">Takk for spørsmålet! Jeg noterer dette og sørger for at {{ megler.navn }} gir deg et presist svar. Er det noe annet jeg kan hjelpe med?</div>`;
                chatBody.scrollTop = chatBody.scrollHeight;
            }, 1000);
        }
    </script>
</body>
</html>

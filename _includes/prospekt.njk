<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - THOMPSON & CO</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Segoe+UI:wght@400;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --plum-dark: #3d1328;
            --plum-light: #6b2247;
            --text-dark: #333333;
            --text-light: #ffffff;
            --bg-light: #fdfafb;
            --border-color: #e0e0e0;
            --pink-accent: #d1a3b8;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, sans-serif; }
        body { background-color: var(--bg-light); color: var(--text-dark); line-height: 1.6; }
        
        /* Header & Logo */
        header { background: linear-gradient(rgba(0,0,0,0.8), transparent); color: white; padding: 1.5rem 5%; position: absolute; top: 0; width: 100%; z-index: 100; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; letter-spacing: 2px; text-decoration: none; color: white; }
        .back-link { color: white; text-decoration: none; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }

        /* Hero / Hovedbilde */
        .hero { width: 100%; height: 70vh; position: relative; overflow: hidden; background-color: var(--plum-dark); }
        .hero img { width: 100%; height: 100%; object-fit: cover; }

        /* Innhold */
        .container { max-width: 1200px; margin: 0 auto; padding: 4rem 5%; display: grid; grid-template-columns: 2fr 1fr; gap: 4rem; }
        
        h1 { font-family: 'Playfair Display', serif; font-size: 3rem; color: var(--plum-dark); margin-bottom: 0.5rem; }
        .subtitle { font-size: 1.2rem; color: #666; margin-bottom: 2rem; text-transform: uppercase; letter-spacing: 1px; }
        
        .main-content { font-size: 1.1rem; color: #444; }

        /* Galleri Rutenett */
        .gallery-section { grid-column: 1 / -1; margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 3rem; }
        .gallery-title { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--plum-dark); margin-bottom: 2rem; }
        .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px; }
        .gallery-grid img { width: 100%; aspect-ratio: 3/2; object-fit: cover; border-radius: 4px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: transform 0.3s ease; }
        .gallery-grid img:hover { transform: scale(1.02); }

        /* Sidebar */
        .sidebar { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); height: max-content; border-top: 4px solid var(--plum-dark); }
        .sidebar h3 { font-family: 'Playfair Display', serif; margin-bottom: 1rem; color: var(--plum-dark); }
        .contact-info { margin-bottom: 1.5rem; font-size: 0.95rem; }
        .btn { display: block; width: 100%; padding: 1rem; background: var(--plum-dark); color: white; text-align: center; text-decoration: none; border-radius: 4px; font-weight: 600; transition: background 0.3s; }
        .btn:hover { background: var(--plum-light); }

        @media (max-width: 900px) {
            .container { grid-template-columns: 1fr; }
            h1 { font-size: 2.2rem; }
        }
    </style>
</head>
<body>

    <header>
        <a href="/" class="logo">THOMPSON & CO.</a>
        <a href="/lokaler" class="back-link">← Tilbake til lokaler</a>
    </header>

    <section class="hero">
        {% if galleri and galleri.length > 0 %}
            <img src="{{ galleri[0] }}" alt="{{ title }}">
        {% else %}
            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: white;">Intet bilde valgt</div>
        {% endif %}
    </section>

    <main class="container">
        <div class="content-area">
            <h1>{{ title }}</h1>
            <p class="subtitle">{{ subtitle }}</p>
            
            <div class="main-content">
                {{ content | safe }}
            </div>
        </div>

        <aside class="sidebar">
            <h3>Interessert i lokalet?</h3>
            <div class="contact-info">
                <p><strong>Emil Thompson</strong></p>
                <p>Senior Rådgiver</p>
                <p style="margin-top: 10px;">+47 44 55 66 77</p>
                <p>emil@thompsonco.no</p>
            </div>
            <a href="mailto:emil@thompsonco.no" class="btn">Kontakt oss</a>
        </aside>

        {% if galleri and galleri.length > 1 %}
        <section class="gallery-section">
            <h2 class="gallery-title">Flere bilder</h2>
            <div class="gallery-grid">
                {% for bilde in galleri %}
                    {% if not loop.first %}
                        <img src="{{ bilde }}" alt="Bilde fra {{ title }}">
                    {% endif %}
                {% endfor %}
            </div>
        </section>
        {% endif %}
    </main>

    <footer style="background: var(--plum-dark); color: white; text-align: center; padding: 3rem; margin-top: 5rem;">
        <p>&copy; 2026 Thompson & Co. Eiendomsutvikling.</p>
    </footer>

</body>
</html>

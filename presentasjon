<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Tjuvholmen Allé 3 | THOMPSON & CO</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --brand-main: #23377B; 
            --brand-light: #E6F2FF; 
            --brand-hover: #314B9E; 
            --brand-text: #4A5D7E; 
            --bg-white: #FFFFFF;
            --text-dark: #111111;
            --text-grey: #666666;
            --border-light: #E5E5E5;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        html, body { font-family: 'Inter', sans-serif; background-color: var(--bg-white); color: var(--text-dark); margin: 0; line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
        .container { max-width: 1280px; margin: 0 auto; padding: 0 40px; }
        
        /* --- HEADER & NAVIGASJON --- */
        header { display: flex; justify-content: space-between; align-items: center; padding: 40px 0; margin-bottom: 50px; }
        .logo { font-size: 20px; font-weight: 800; color: var(--brand-main); text-decoration: none; text-transform: uppercase; }
        .top-menu-btn { font-size: 18px; font-weight: 800; cursor: pointer; color: var(--brand-main); letter-spacing: 0.5px; transition: opacity 0.2s; }
        .top-menu-btn:hover { opacity: 0.8; }

        .top-nav-bar { margin-bottom: 30px; display: flex; align-items: center; }
        .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--brand-main); text-decoration: none; font-size: 16px; font-weight: 600; transition: opacity 0.2s; }
        .back-link:hover { opacity: 0.8; }
        .back-link svg { width: 18px; height: 18px; stroke-width: 2.5; }

        /* --- HOVED GALLERI (Desktop Grid / Mobil Swipe) --- */
        .hero-gallery { position: relative; margin-bottom: 40px; border-radius: 12px; overflow: hidden; }
        .gallery-track { display: grid; grid-template-columns: 2fr 1fr; grid-template-rows: 250px 250px; gap: 10px; width: 100%; height: 100%; }
        
        .hero-img { width: 100%; height: 100%; object-fit: cover; transition: filter 0.3s; cursor: pointer; }
        .hero-img:hover { filter: brightness(0.9); }
        .img-main { grid-row: 1 / 3; }
        .mobile-only-img { display: none; }
        
        .gallery-count { position: absolute; bottom: 20px; right: 20px; background: rgba(0,0,0,0.7); color: white; padding: 8px 16px; border-radius: 50px; font-size: 12px; font-weight: 600; backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); pointer-events: none; z-index: 10; }
        
        .gallery-dots-wrapper { display: none; }

        /* --- MOBIL MEGLER ACCORDION (Skjult på desktop) --- */
        .mobile-broker-accordion { display: none; }

        /* --- FULL BREDDE HEADER SEKSJON --- */
        .header-section-full { margin-bottom: 80px; padding-bottom: 40px; border-bottom: 1px solid var(--border-light); }
        
        /* Badges (Til leie + Oslo) samlet på en linje - nå med lik farge */
        .badge-row { display: flex; gap: 10px; margin-bottom: 15px; }
        .status-badge { display: inline-block; background: var(--brand-light); color: var(--brand-main); padding: 6px 12px; font-size: 11px; text-transform: uppercase; font-weight: 800; border-radius: 4px; letter-spacing: 0.5px; }
        .area-badge { display: inline-block; background: var(--brand-light); color: var(--brand-main); padding: 6px 12px; font-size: 11px; text-transform: uppercase; font-weight: 800; border-radius: 4px; letter-spacing: 0.5px; }
        
        .page-title { font-size: 48px; font-weight: 600; margin: 0 0 15px 0; color: var(--brand-main); letter-spacing: -1px; line-height: 1.1; }
        .property-subtitle { font-size: 18px; color: var(--text-grey); font-weight: 300; margin: 0 0 30px 0; max-width: 800px; line-height: 1.6; }
        
        .action-bar { display: flex; gap: 10px; flex-wrap: wrap; }
        .action-pill { display: inline-flex; align-items: center; gap: 8px; background: var(--brand-light); color: var(--brand-main); padding: 12px 20px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s; border: 1px solid transparent; cursor: pointer; }
        .action-pill:hover { background: var(--brand-main); color: white; transform: translateY(-2px); }
        .action-pill svg { width: 16px; height: 16px; }
        .action-pill.icon-only { padding: 12px 16px; }
        .mobile-only-pill { display: none !important; }

        /* --- LAYOUT --- */
        .prospect-layout { display: flex; gap: 70px; margin-bottom: 100px; align-items: flex-start; }
        .main-content { flex: 1; min-width: 0; }
        .sidebar { width: 340px; position: sticky; top: 40px; flex-shrink: 0; }

        /* --- NØKKELINFO --- */
        .key-facts-container { margin-bottom: 80px; }
        .key-facts-main-title { font-size: 28px; font-weight: 600; color: var(--brand-main); margin: 0 0 40px 0; letter-spacing: -1px; }
        
        .key-facts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 50px 30px; }
        .fact-item { display: flex; flex-direction: column; gap: 6px; }
        .fact-label { font-size: 11px; text-transform: uppercase; color: #A0AABF; font-weight: 500; letter-spacing: 0.5px; } 
        .fact-value { font-size: 22px; font-weight: 400; color: var(--brand-main); line-height: 1.1; letter-spacing: -0.5px;}

        /* --- OPPSUMMERING --- */
        .highlights-container { background-color: var(--brand-light); border-radius: 12px; padding: 40px; margin-bottom: 90px; }
        .hl-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
        .hl-header h2 { margin: 0; font-size: 28px; font-weight: 600; color: var(--brand-main); letter-spacing: -1px; }
        .hl-content { display: block; overflow: hidden; }
        .highlights-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px; }
        .highlights-list li { display: flex; align-items: flex-start; gap: 14px; font-size: 16px; font-weight: 300; color: var(--text-dark); line-height: 1.6; }
        .highlights-list li svg { flex-shrink: 0; width: 22px; height: 22px; color: var(--brand-main); margin-top: 2px; stroke-width: 1.5; }
        .highlight-bold { font-weight: 500; color: var(--brand-main); }

        /* --- GENERELLE SEKSJONER --- */
        .section-wrapper { margin-bottom: 90px; } 
        .section-header { font-size: 28px; font-weight: 600; color: var(--brand-main); margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; letter-spacing: -1px; cursor: pointer; }
        
        .section-content { display: block; overflow: hidden; }
        .arrow-icon { display: none; width: 24px; height: 24px; color: var(--brand-main); transition: transform 0.3s ease; }
        
        .desktop-closed .section-content { display: none !important; }
        .desktop-closed .arrow-icon { display: block !important; }
        .desktop-closed.active .section-content { display: block !important; animation: fadeIn 0.4s ease; }
        .desktop-closed.active .arrow-icon { transform: rotate(180deg) !important; }

        .description-text { font-weight: 300; line-height: 1.8; color: var(--text-dark); margin-bottom: 15px; font-size: 16px;}
        
        .energy-label-box { display: flex; align-items: center; gap: 12px; margin-top: 20px; }
        .energy-label-text { font-weight: 300; font-size: 16px; color: var(--text-dark); }
        .energy-house-icon { background: #8CC63F; color: white; display: flex; align-items: center; justify-content: center; width: 18px; height: 18px; font-weight: 700; font-size: 10px; clip-path: polygon(50% 0%, 100% 25%, 100% 100%, 0 100%, 0% 25%); }

        .address-text { font-weight: 500; font-size: 16px; color: var(--brand-main); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
        .copy-icon-btn { background: transparent; border: none; color: var(--text-grey); cursor: pointer; display: inline-flex; align-items: center; justify-content: center; padding: 4px; transition: color 0.2s ease; outline: none; margin-left: 5px; }
        .copy-icon-btn svg { width: 16px; height: 16px; }
        .copy-icon-btn:hover { color: var(--brand-main); transform: scale(1.1); }

        /* --- FASILITETER --- */
        .facilities-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 30px; width: 100%; }
        .facility-item { display: flex; align-items: center; gap: 14px; font-size: 15px; font-weight: 400; color: var(--text-dark); word-break: break-word; }
        .facility-item svg { color: var(--brand-main); flex-shrink: 0; width: 20px; height: 20px; stroke-width: 1.5; }

        .fac-slider-wrapper { position: relative; display: flex; align-items: center; }
        .fac-slider-container { display: flex; gap: 16px; overflow-x: auto; padding-bottom: 15px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; flex: 1; }
        .fac-slider-container::-webkit-scrollbar { display: none; }
        .fac-slider-img { width: 180px; height: 120px; border-radius: 8px; object-fit: cover; scroll-snap-align: start; flex-shrink: 0; transition: opacity 0.3s; cursor: pointer; border: 1px solid var(--border-light); }
        .fac-slider-img:hover { opacity: 0.8; }
        
        .fac-nav { position: absolute; z-index: 5; background: var(--bg-white); border: 1px solid var(--border-light); color: var(--brand-main); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.05); font-size: 18px; transition: 0.2s; outline: none; }
        .fac-nav:hover { background: var(--brand-main); color: white; border-color: var(--brand-main); }
        .fac-nav.prev { left: -20px; }
        .fac-nav.next { right: -20px; }

        /* --- DOKUMENTER --- */
        .doc-list { display: flex; flex-direction: column; gap: 12px; }
        .doc-link { display: inline-flex; align-items: center; gap: 10px; color: var(--brand-main); text-decoration: none; font-weight: 500; font-size: 15px; padding: 12px 16px; background: var(--brand-light); border-radius: 6px; transition: background 0.2s; width: fit-content;}
        .doc-link:hover { background: var(--border-light); }
        .doc-link svg { width: 18px; height: 18px; }

        /* --- KART --- */
        .map-placeholder { width: 100%; height: 350px; border-radius: 12px; margin-bottom: 20px; border: 1px solid rgba(35, 55, 123, 0.1); overflow: hidden; background: var(--brand-light); }
        .map-placeholder iframe { width: 100%; height: 100%; border: none; filter: grayscale(0.5) sepia(0.1) hue-rotate(190deg); }
        
        .travel-calc-wrapper { margin-top: 20px; }
        .travel-calc { background: var(--brand-light); padding: 30px; border-radius: 8px; margin-top: 15px; display: none; border: 1px solid rgba(35, 55, 123, 0.1); }
        .travel-calc.show { display: block; animation: fadeIn 0.3s ease; }
        .travel-header { font-weight: 600; margin-bottom: 15px; color: var(--brand-main); font-size: 15px; }
        .travel-input-group { display: flex; gap: 10px; margin-bottom: 25px; }
        .travel-input { flex: 1; padding: 14px; border: 1px solid var(--border-light); border-radius: 4px; font-family: inherit; font-size: 15px; outline: none; }
        .travel-results { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .travel-mode { background: white; padding: 15px; border-radius: 6px; text-align: center; font-size: 12px; border: 1px solid var(--border-light); }
        .travel-mode span { display: block; font-weight: 700; font-size: 18px; color: var(--brand-main); margin-top: 4px;}

        /* --- TREKKSPILL GRUPPE (Bunn) --- */
        .accordion-group { border-top: 1px solid var(--border-light); margin-top: 60px; }
        .accordion-group .section-wrapper { margin-bottom: 0; padding: 35px 0; border-bottom: 1px solid var(--border-light); }
        .accordion-group .section-header { margin-bottom: 0; font-size: 28px; }
        
        .accordion-group .section-wrapper.active { border-bottom-color: transparent; padding-bottom: 60px; }
        .accordion-group .section-wrapper.active .section-header { margin-bottom: 30px; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        /* --- MEGLER KORT (Desktop Sidebar) --- */
        .broker-container { display: flex; flex-direction: column; gap: 50px; }
        
        .broker-card { 
            background: var(--brand-main); 
            border-radius: 12px; 
            color: var(--bg-white); 
            box-shadow: 0 10px 30px rgba(35, 55, 123, 0.1); 
            overflow: hidden; 
            display: flex; 
            flex-direction: column; 
        }
        
        .broker-img-wrapper {
            position: relative;
            width: 100%;
            padding-bottom: 100%; 
            overflow: hidden;
            background: var(--brand-main);
        }
        .broker-img-wrapper img {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            object-fit: cover;
            object-position: top center;
        }
        
        .broker-details { 
            padding: 25px 25px; 
            display: flex; 
            flex-direction: column; 
        }

        .broker-details .broker-title { margin: 0 0 6px 0; color: var(--brand-light); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.9; }
        .broker-details h3 { margin: 0 0 20px 0; color: var(--bg-white); font-size: 24px; font-weight: 600; letter-spacing: -0.5px; }
        
        .broker-contact-links { display: flex; flex-direction: column; gap: 12px; }
        .broker-contact-links a { font-size: 15px; color: var(--bg-white); text-decoration: none; font-weight: 400; display: inline-flex; align-items: center; gap: 10px; transition: all 0.2s;}
        .broker-contact-links a:hover { opacity: 0.8; text-decoration: underline; }
        
        .broker-email-row { display: flex; align-items: center; justify-content: flex-start; gap: 6px; }
        .broker-email-row a { margin-right: 0; }
        .broker-email-row .copy-icon-btn { padding: 4px; margin: 0; color: var(--brand-light); }
        .broker-email-row .copy-icon-btn:hover { color: white; transform: scale(1.1); }

        /* --- FOOTER METADATA --- */
        .prospect-meta-footer {
            margin-top: 40px;
            padding-top: 0;
            border-top: none;
            font-size: 12px;
            color: var(--text-grey);
            line-height: 1.8;
            font-weight: 500;
        }
        .prospect-meta-footer p { margin: 0; }

        /* --- LIGHTBOX --- */
        .lightbox { display: none; position: fixed; top:0; left:0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 1000; flex-direction: column; align-items: center; justify-content: center; }
        .lightbox.active { display: flex; }
        .lightbox-main { max-width: 85%; max-height: 70vh; object-fit: contain; }
        .lightbox-nav { position: absolute; width: 100%; display: flex; justify-content: space-between; padding: 0 50px; color: white; font-size: 40px; cursor: pointer; z-index: 1001; }
        .lightbox-nav span { background: rgba(255,255,255,0.1); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: background 0.2s;}
        .lightbox-nav span:hover { background: rgba(255,255,255,0.3); }
        
        .lightbox-thumbs { display: flex; gap: 10px; margin-top: 30px; overflow-x: auto; max-width: 90%; padding-bottom: 10px; scrollbar-width: none; -ms-overflow-style: none; }
        .lightbox-thumbs::-webkit-scrollbar { display: none; }
        
        .thumb-item { width: 70px; height: 50px; object-fit: cover; opacity: 0.4; cursor: pointer; border-radius: 4px; border: 2px solid transparent;}
        .thumb-item.active { opacity: 1; border: 2px solid var(--brand-light); }
        .close-lightbox { position: absolute; top: 30px; right: 40px; color: white; font-size: 40px; cursor: pointer; z-index: 1001; line-height: 1;}

        /* --- MOBIL JUSTERING --- */
        @media (max-width: 900px) {
            .container { padding: 0 20px; }
            .prospect-layout { flex-direction: column; gap: 40px;} 
            
            .sidebar { display: none; }
            
            .page-title { font-size: 32px; }
            .property-subtitle { font-size: 16px; margin-bottom: 20px; }
            
            .status-badge-floating { display: none; } /* Vi flyttet denne til header-seksjonen */
            
            /* MOBIL SWIPE-GALLERI */
            .hero-gallery { margin-bottom: 25px; border-radius: 12px;}
            .gallery-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; height: 350px; gap: 0; scrollbar-width: none; }
            .gallery-track::-webkit-scrollbar { display: none; }
            .gallery-track img { flex: 0 0 100%; scroll-snap-align: start; height: 100%; object-fit: cover; }
            .mobile-only-img { display: block; }
            
            .gallery-dots-wrapper { display: flex; justify-content: center; position: absolute; bottom: 20px; left: 0; width: 100%; z-index: 20; pointer-events: none;}
            .gallery-dots { display: flex; gap: 8px; }
            .gallery-dots .dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.4); transition: all 0.3s; }
            .gallery-dots .dot.active { background: #fff; transform: scale(1.3); }

            /* MOBIL MEGLER ACCORDION */
            .mobile-broker-accordion { display: block; margin-bottom: 30px; }
            .mb-header { background: var(--brand-main); color: white; border-radius: 50px; padding: 6px 20px 6px 6px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; box-sizing: border-box;}
            
            .mb-left { display: flex; align-items: center; gap: 12px; font-weight: 600; font-size: 15px; min-width: 0; flex: 1; padding-right: 10px;}
            .mb-left span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
            
            .mb-avatars { display: flex; align-items: center; margin-right: 5px; flex-shrink: 0; }
            .mb-avatars img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 2px solid var(--brand-main); }
            .mb-avatars .avatar-overlap { margin-left: -12px; }

            .mb-arrow { flex-shrink: 0; width: 20px; height: 20px; transition: transform 0.3s; color: white; }
            .mobile-broker-accordion.active .mb-arrow { transform: rotate(180deg); }
            
            .mb-content { display: none; padding-top: 15px; flex-direction: column; gap: 15px; }
            .mobile-broker-accordion.active .mb-content { display: flex; animation: fadeIn 0.3s ease; }
            
            .mb-card { display: flex; align-items: center; gap: 20px; background: var(--bg-white); padding: 15px; border-radius: 12px; border: 1px solid var(--border-light); }
            .mb-card img { width: 70px; height: 70px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 1px solid var(--border-light);}
            .mb-info { display: flex; flex-direction: column; gap: 4px; width: 100%; }
            
            /* Mobil Megler Tittel / Navn Swap */
            .mb-info .mb-title { margin: 0 0 2px 0; font-size: 11px; text-transform: uppercase; color: var(--brand-text); font-weight: 600; }
            .mb-info h3 { margin: 0 0 8px 0; font-size: 18px; color: var(--brand-main); font-weight: 600; letter-spacing: -0.5px; }
            
            .mb-info a { color: var(--brand-main); text-decoration: none; font-size: 14px; font-weight: 500; display: inline-block;}
            .mb-info .mb-msg { text-decoration: none; margin-top: 4px; opacity: 0.9; }
            
            .mb-info .broker-email-row { display: flex; align-items: center; gap: 6px; justify-content: flex-start; }
            .mb-info .broker-email-row a { margin-right: 0; }
            .mb-info .copy-icon-btn { padding: 4px; margin: 0; color: var(--text-grey); }
            .mb-info .copy-icon-btn:hover { color: var(--brand-main); transform: scale(1.1); }

            .action-bar { justify-content: flex-start; gap: 8px;}
            
            .key-facts-grid { grid-template-columns: 1fr 1fr; gap: 30px 15px; }
            
            /* OPPSUMMERING BOKS PÅ MOBIL (Ikke nedtrekk) */
            .highlights-container { padding: 30px 25px; margin-bottom: 50px; }
            .hl-header { display: flex; justify-content: flex-start; margin-bottom: 20px; pointer-events: none; }
            .hl-header h2 { font-size: 24px; margin: 0; }

            .facilities-grid { grid-template-columns: 1fr; width: 100%; }
            .fac-nav { display: none; } 
            
            .travel-input-group { flex-direction: column; }
            .travel-results { grid-template-columns: 1fr; }
            .travel-input { font-size: 16px !important; } 

            .key-facts-main-title { font-size: 24px; margin-bottom: 20px; }
            .section-header { font-size: 24px; }
            .accordion-group .section-header { font-size: 24px; }

            /* På mobil skal faner fungere som lukkede trekkspill, med unntak av .active (Om lokalet) */
            .section-wrapper { border-bottom: 1px solid var(--border-light); padding: 30px 0; margin-bottom: 0; }
            .section-header { margin-bottom: 0; padding: 5px 0; }
            .arrow-icon { display: block !important; }
            
            .accordion-group { border-top: none; margin-top: 0; }
            .accordion-group .section-wrapper:first-child { border-top: none; padding-top: 0; }

            .section-content { display: none !important; padding-top: 25px; }
            .section-wrapper.active .section-content { display: block !important; }
            .section-wrapper.active .arrow-icon { transform: rotate(180deg) !important; }
            .section-wrapper.active { border-bottom-color: transparent; padding-bottom: 40px;}

            .prospect-meta-footer { text-align: center; margin-top: 40px; margin-bottom: 40px; }
        }
        @media (min-width: 901px) {
            .section-wrapper:not(.desktop-closed) .section-content { display: block !important; }
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <a href="#" class="logo">THOMPSON & CO</a>
            <div class="top-menu-btn">Meny</div>
        </header>

        <div class="top-nav-bar">
            <a href="#" class="back-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Tilbake
            </a>
        </div>

        <div class="hero-gallery">
            <div class="gallery-track" id="main-gallery-track" onscroll="updateMainDots()">
                <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=1200" class="hero-img img-main" onclick="openLightbox(0, 'main')">
                <img src="https://images.unsplash.com/photo-1524758631624-e2822e304c36?auto=format&fit=crop&q=80&w=800" class="hero-img img-sub" onclick="openLightbox(1, 'main')">
